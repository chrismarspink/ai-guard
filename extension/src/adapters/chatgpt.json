{
  "_comment": "Selectors are DOM-derived best-effort and need periodic verification since ChatGPT's UI changes without notice (risk R1).",
  "id": "chatgpt",
  "urls": ["https://chat.openai.com/*", "https://chatgpt.com/*"],
  "adapterVersion": "1.0.0",
  "selectors": {
    "input": "#prompt-textarea",
    "sendButton": "button[data-testid=\"send-button\"]",
    "fileInput": "input[type=\"file\"]"
  },
  "endpoints": {
    "uploadUrlPattern": "*://*chatgpt.com/backend-api/*files*"
  }
}
