DATABASE_URL=postgresql+psycopg2://ai_guard:ai_guard@postgres:5432/ai_guard
REDIS_URL=redis://redis:6379/0
JWT_SECRET=replace-with-a-long-random-value
FLEET_WEBHOOK_SECRET=replace-with-a-long-random-value

# Dev-only bootstrap admin -- both must be set for the seed to run. Leave
# unset in any shared/prod environment; rotate or delete the account after
# first login if you do use it. See README.md "Dev admin seed" section.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

POSTGRES_DB=ai_guard
POSTGRES_USER=ai_guard
POSTGRES_PASSWORD=ai_guard
